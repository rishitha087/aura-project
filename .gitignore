# ─── PrepSync Root .gitignore ──────────────────────────────────────────────────
# This file covers the entire monorepo (backend/ + frontend/).

# ── Python / Django ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
venv/
env/
.venv/
ENV/
backend/venv/
backend/env/

# Django
*.log
backend/local_settings.py
backend/db.sqlite3
backend/db.sqlite3-journal

# Media files — user uploads, lives on Railway volume
backend/media/

# Static files — generated by collectstatic at deploy time
backend/staticfiles/

# ── Node.js / React ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.cache/
*.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment Variables (NEVER COMMIT SECRETS) ──────────────────────────────
.env
.env.local
.env.production
backend/.env
frontend/.env
frontend/.env.production

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Testing & Coverage ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── Build Artifacts ───────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
