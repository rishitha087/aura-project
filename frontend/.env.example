# PrepSync Frontend — Environment Variables Example
# Copy this to '.env' for local development, or set in Vercel settings.

# URL pointing to your Render backend API.
# - Local Dev default: http://localhost:8000/api
# - Production/Vercel: https://your-backend-app.onrender.com/api
VITE_API_URL=https://REPLACE_WITH_YOUR_RENDER_BACKEND_URL.onrender.com/api
