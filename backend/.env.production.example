# ─────────────────────────────────────────────────────────────────
#  PrepSync Backend — Production Environment Variables Template
#  Copy this to Railway's "Variables" section for the backend service.
#  DO NOT commit real values to Git.
# ─────────────────────────────────────────────────────────────────

# ── DJANGO CORE ──────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_50_CHAR_RANDOM_STRING

# Set to production (Railway sets this automatically when RAILWAY_ENVIRONMENT=production)
RAILWAY_ENVIRONMENT=production

# Your Railway backend subdomain AND any custom domain (comma-separated, no spaces)
ALLOWED_HOSTS=your-backend.up.railway.app,api.yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────
# Your deployed frontend URL(s) — comma-separated, full https URL, no trailing slash
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app,https://yourdomain.com

# ── AI (GOOGLE GEMINI) ───────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
# Must start with AIzaSy...
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_REAL_KEY

# ── PAYMENTS (RAZORPAY) ──────────────────────────────────────────
# Use rzp_test_... for testing, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_REPLACE
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET

# ── EMAIL OTP (PLACEHOLDER — not active yet) ─────────────────────
# When ready to activate, set EMAIL_OTP_ENABLED=true and fill these
EMAIL_OTP_ENABLED=false
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── SMS OTP (PLACEHOLDER — not active yet) ───────────────────────
# When ready to activate (Twilio), set SMS_OTP_ENABLED=true and fill these
SMS_OTP_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── DATABASE ─────────────────────────────────────────────────────
# SQLite path is hardcoded to /data/db.sqlite3 in production (Railway volume)
# No DATABASE_URL needed for SQLite — it's handled in settings.py automatically
# If you ever upgrade to PostgreSQL, set DATABASE_URL here and update settings.py

# ── RAILWAY VOLUME ───────────────────────────────────────────────
# Configure a volume in Railway dashboard → your backend service → Volumes
# Mount path: /data
# This persists db.sqlite3 and all uploaded media files across redeployments.
