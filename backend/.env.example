# ─────────────────────────────────────────────────────────────────
#  PrepSync Backend — Render & Supabase Environment Variables Example
#  Copy this to a file named '.env' in this directory for local dev.
#  For Render, add these in your service's "Environment" tab.
# ─────────────────────────────────────────────────────────────────

# ── DJANGO CONFIG ────────────────────────────────────────────────
# Set to True for local development, False for production/Render
DEBUG=True
IS_PRODUCTION=False

# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-local-dev-only-change-in-production

# Comma-separated hosts allowed to access your API
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ── DATABASE (SUPABASE POSTGRESQL) ──────────────────────────────
# Fill in your Supabase connection string.
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.wmtilxlgwstdnfhatqwe.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:REPLACE_WITH_YOUR_SUPABASE_PASSWORD@db.wmtilxlgwstdnfhatqwe.supabase.co:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origin URLs (e.g. your Vercel frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ── AI (GOOGLE GEMINI) ───────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey (must start with AIzaSy)
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_REAL_KEY


# ── PAYMENTS (RAZORPAY) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_KEY_SECRET

# ── OTP CONFIG (OPTIONAL PLACEHOLDERS) ───────────────────────────
EMAIL_OTP_ENABLED=false
SMS_OTP_ENABLED=false
